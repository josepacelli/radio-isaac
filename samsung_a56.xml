<?xml version="1.0" encoding="UTF-8"?>
<d:devices xmlns:d="http://schemas.android.com/sdk/devices/1">
    <d:device>
        <d:name>Samsung Galaxy A56</d:name>
        <d:manufacturer>Samsung</d:manufacturer>
        <d:meta/>
        <d:hardware>
            <d:screen>
                <d:screen-size>large</d:screen-size>
                <d:diagonal-length>6.7</d:diagonal-length>
                <d:pixel-density>xxhdpi</d:pixel-density>
                <d:screen-ratio>long</d:screen-ratio>
                <d:dimensions>
                    <d:x-dimension>1080</d:x-dimension>
                    <d:y-dimension>2340</d:y-dimension>
                </d:dimensions>
                <d:xdpi>384.0</d:xdpi>
                <d:ydpi>384.0</d:ydpi>
                <d:touch>
                    <d:multitouch>jazz-hands</d:multitouch>
                    <d:mechanism>finger</d:mechanism>
                    <d:screen-type>capacitive</d:screen-type>
                </d:touch>
            </d:screen>
            <d:networking>Bluetooth Wifi NFC</d:networking>
            <d:sensors>Accelerometer Barometer Compass GPS Gyroscope LightSensor ProximitySensor StepDetector StepCounter</d:sensors>
            <d:mic>true</d:mic>
            <d:camera>
                <d:location>back</d:location>
                <d:autofocus>true</d:autofocus>
                <d:flash>true</d:flash>
            </d:camera>
            <d:camera>
                <d:location>front</d:location>
                <d:autofocus>false</d:autofocus>
                <d:flash>false</d:flash>
            </d:camera>
            <d:keyboard>nokeys</d:keyboard>
            <d:nav>nonav</d:nav>
            <d:ram unit="GiB">8</d:ram>
            <d:buttons>soft</d:buttons>
            <d:internal-storage unit="GiB">128</d:internal-storage>
            <d:removable-storage unit="GiB">0</d:removable-storage>
            <d:cpu>Exynos 1580</d:cpu>
            <d:gpu>Mali-G68 MP2</d:gpu>
            <d:abi>
                <d:cpu-arch>arm64-v8a</d:cpu-arch>
            </d:abi>
            <d:dock/>
            <d:power-type>battery</d:power-type>
        </d:hardware>
        <d:software>
            <d:api-level>35-</d:api-level>
            <d:live-wallpaper-support>true</d:live-wallpaper-support>
            <d:bluetooth-profiles/>
            <d:gl-version>3.2</d:gl-version>
            <d:gl-extensions/>
            <d:status-bar>true</d:status-bar>
        </d:software>
        <d:state name="Portrait" default="true">
            <d:description>Portrait</d:description>
            <d:screen-orientation>port</d:screen-orientation>
            <d:keyboard-state>keysexposed</d:keyboard-state>
            <d:nav-state>navhidden</d:nav-state>
        </d:state>
        <d:state name="Landscape">
            <d:description>Landscape</d:description>
            <d:screen-orientation>land</d:screen-orientation>
            <d:keyboard-state>keysexposed</d:keyboard-state>
            <d:nav-state>navhidden</d:nav-state>
        </d:state>
    </d:device>
</d:devices>
